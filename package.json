  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web...",
    "dev:cli": "turbo dev --filter=cli...",
    "dev:bot": "turbo dev --filter=bot...",
    "lint": "turbo lint",
